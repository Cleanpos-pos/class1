# ===========================================
# CleanPOS Environment Configuration
# ===========================================
# SECURITY: Never commit real values to git!
# Copy this file to .env.local and fill in your values
# ===========================================

# Supabase Configuration
# Get these from: Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Brevo Email Service (formerly Sendinblue)
# Get from: Brevo Dashboard -> SMTP & API -> API Keys
VITE_BREVO_API_KEY=your-brevo-api-key
VITE_BREVO_SMTP_SERVER=smtp-relay.brevo.com
VITE_BREVO_SMTP_PORT=587
VITE_BREVO_SMTP_USER=your-sender-email@domain.com

# Google Maps API (optional - for address autocomplete)
# Get from: Google Cloud Console -> APIs & Services -> Credentials
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ===========================================
# BACKEND-ONLY SECRETS (Supabase Edge Functions)
# These should NEVER be in client-side code!
# Set these in: Supabase Dashboard -> Edge Functions -> Secrets
# ===========================================
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# BREVO_API_KEY=same-as-above-for-edge-functions
# GEMINI_API_KEY=your-gemini-api-key (backend only!)
